# HTTP
PORT=8788

# Stamp/owner/redeem writes may only be called from this base domain and its
# subdomains (e.g. gnosis.io allows circles.gnosis.io, circles-dev.gnosis.io). https only.
ALLOWED_BASE_DOMAIN=gnosis.io
# Optional comma-separated extra origins for local dev (exact match), e.g.
# EXTRA_ALLOWED_ORIGINS=http://localhost:5173
EXTRA_ALLOWED_ORIGINS=

# Gnosis Chain RPC used for reads + sending the group Safe's transactions.
RPC_URL=https://rpc.gnosischain.com

# The coffee shop's Circles GROUP (a Safe avatar registered as a group).
GROUP_SAFE_ADDRESS=

# OWNER: the address shown the dashboard / allowed to redeem. Usually the same
# avatar that controls the shop (compared client-side to switch to the owner view).
OWNER_ADDRESS=

# OPERATOR: an EOA that is an owner/signer of GROUP_SAFE_ADDRESS (so it can sign
# Hub.trust FROM the group Safe) AND is the `minter` on the CoffeeStampNFT.
# This is a HOT KEY — keep it secret, never commit it.
OPERATOR_PRIVATE_KEY=

# The deployed CoffeeStampNFT contract (see ../contracts). Operator must be minter.
NFT_CONTRACT_ADDRESS=

# If 'true', only registered Circles humans may collect stamps (extra gate).
REQUIRE_HUMAN=false

# Per-IP rate limit for write endpoints.
RATE_WINDOW_MS=60000   # short window length (ms)
RATE_MAX=10            # max requests per short window per IP
RATE_DAILY_MAX=60      # max requests per 24h per IP

# Loyalty state JSON file (created if missing).
STORE_FILE=./data/loyalty.json
