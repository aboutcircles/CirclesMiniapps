VITE_COMETH_API_KEY=
VITE_PIMLICO_API_KEY=
VITE_PIMLICO_SPONSORSHIP_POLICY_ID=   # required for sign-up + /fcboarding — sponsors gas so the new Safe deploys without funds
VITE_INVITE_BACKEND_URL=              # circles-invite-backend URL (e.g. http://localhost:8787); sign-up invites the new Safe to Circles via it
VITE_BASE_URL=

VITE_MIXPANEL_TOKEN=
VITE_MIXPANEL_API_HOST=https://api-eu.mixpanel.com
VITE_MIXPANEL_DEBUG=true
VITE_APP_ENV=dev
VITE_ANALYTICS_ENABLED=false

# Circles Amsterdam (dAMS) pilot — service that adds new users to the dAMS group
VITE_DAMS_MEMBERSHIP_URL=https://amsterdam-ashy.vercel.app/api/add-member
# Optional: override participating shops (JSON array of { address, name, offer })
# VITE_DAMS_SHOPS=

# Rep Score Explorer (/apps/rep-score-explorer) — all optional, PRODUCTION defaults.
# Point the three base URLs at the staging dataset for QA:
#   VITE_REP_SCORE_BASE=https://rpc.staging.aboutcircles.com/analytics/rep_score
#   VITE_REP_SCORE_RPC_BASE=https://rpc.staging.aboutcircles.com/
#   VITE_REP_SCORE_PROFILE_BASE=https://rpc.staging.aboutcircles.com/profiles/profile
# VITE_REP_SCORE_BASE=            # analytics rep_score base (default prod)
# VITE_REP_SCORE_RPC_BASE=        # Circles JSON-RPC for batch profiles (default prod)
# VITE_REP_SCORE_PROFILE_BASE=    # profile service base (default prod)
# VITE_REP_SCORE_GROUP_ID=score_group
# VITE_REP_SCORE_SEARCH_ENABLED=true   # set false to ship a personal-only variant (hides search)
# VITE_REP_SCORE_DEBUG=false           # set true (or open the app with ?debug=1) to show the developer Debug tab
